# Chave do OpenRouter — usada SOMENTE no servidor (server/index.ts).
# Nunca é exposta ao navegador. Copie este arquivo para .env e preencha.
# Crie a chave em https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-...

# Porta do proxy de extração (opcional; padrão 8788).
PORT=8788

# Modelo de extração — qualquer ID do OpenRouter (https://openrouter.ai/models).
EXTRACTION_MODEL=openai/gpt-4o-mini

# Log de sessões em logs/ (gitignored). false para desligar. Padrão: ligado.
LOG_SESSOES=true
