{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$description": "Unfold OS — design tokens portáveis (formato W3C). Importe em Figma, Tailwind, Style Dictionary, etc.",
  "color": {
    "$type": "color",
    "palette": {
      "azul-profundo": { "$value": "#0e142b", "$description": "Deep — fundo de confiança e texto principal" },
      "indigo": { "$value": "#24385a", "$description": "Índigo — primário" },
      "grafite": { "$value": "#485563", "$description": "Graphite — texto secundário" },
      "pedra": { "$value": "#e7eaee", "$description": "Stone — bordas e divisores" },
      "areia": { "$value": "#f3f6f8", "$description": "Sand — a canvas" },
      "salvia": { "$value": "#3fa688", "$description": "Sage — diagnóstico saudável" },
      "ambar": { "$value": "#d4af37", "$description": "Amber — acento sutil" }
    },
    "neutral": {
      "0": { "$value": "#ffffff" },
      "50": { "$value": "#f8fafb" },
      "100": { "$value": "#f3f6f8" },
      "150": { "$value": "#eceff3" },
      "200": { "$value": "#e7eaee" },
      "300": { "$value": "#d5dae1" },
      "400": { "$value": "#aeb6c1" },
      "500": { "$value": "#8a94a3" },
      "600": { "$value": "#677085" },
      "700": { "$value": "#485563" },
      "800": { "$value": "#2c3848" },
      "900": { "$value": "#1a2233" },
      "950": { "$value": "#0e142b" }
    },
    "indigo": {
      "50": { "$value": "#eef1f7" }, "100": { "$value": "#d8dfec" }, "200": { "$value": "#b3c0da" },
      "300": { "$value": "#8093bc" }, "400": { "$value": "#51689b" }, "500": { "$value": "#24385a" },
      "600": { "$value": "#1e2f4c" }, "700": { "$value": "#18263d" }, "800": { "$value": "#121c2e" },
      "900": { "$value": "#0e142b" }
    },
    "sage": {
      "50": { "$value": "#ecf6f2" }, "100": { "$value": "#d2ebe2" }, "200": { "$value": "#a6d7c6" },
      "300": { "$value": "#79c3a9" }, "400": { "$value": "#56b295" }, "500": { "$value": "#3fa688" },
      "600": { "$value": "#348b72" }, "700": { "$value": "#2a6f5b" }, "800": { "$value": "#205445" },
      "900": { "$value": "#163a30" }
    },
    "amber": {
      "50": { "$value": "#faf4e2" }, "100": { "$value": "#f3e6be" }, "200": { "$value": "#e8d08a" },
      "300": { "$value": "#ddbc5c" }, "400": { "$value": "#d4af37" }, "500": { "$value": "#be9a2c" },
      "600": { "$value": "#9c7e24" }, "700": { "$value": "#7a631c" }, "800": { "$value": "#574716" },
      "900": { "$value": "#3a2f0f" }
    },
    "semantic": {
      "canvas": { "$value": "{color.palette.areia}" },
      "surface": { "$value": "{color.neutral.0}" },
      "ink": { "$value": "{color.palette.azul-profundo}" },
      "ink-secondary": { "$value": "{color.palette.grafite}" },
      "border": { "$value": "{color.palette.pedra}" },
      "primary": { "$value": "{color.indigo.500}" },
      "accent": { "$value": "{color.amber.400}" },
      "positive": { "$value": "{color.sage.500}" },
      "attention": { "$value": "{color.amber.400}" },
      "forming": { "$value": "{color.indigo.300}" }
    }
  },
  "fontFamily": {
    "$type": "fontFamily",
    "sans": { "$value": ["Inter", "system-ui", "sans-serif"] },
    "mono": { "$value": ["IBM Plex Mono", "ui-monospace", "monospace"] }
  },
  "fontWeight": {
    "$type": "fontWeight",
    "regular": { "$value": 400 },
    "medium": { "$value": 500 },
    "semibold": { "$value": 600 }
  },
  "fontSize": {
    "$type": "dimension",
    "display": { "$value": "56px" },
    "title-1": { "$value": "40px" },
    "title-2": { "$value": "28px" },
    "title-3": { "$value": "20px" },
    "body-lg": { "$value": "18px" },
    "body": { "$value": "16px" },
    "label": { "$value": "14px" },
    "caption": { "$value": "12px" },
    "overline": { "$value": "11px" }
  },
  "spacing": {
    "$type": "dimension",
    "0": { "$value": "0px" }, "3xs": { "$value": "2px" }, "2xs": { "$value": "4px" },
    "xs": { "$value": "8px" }, "sm": { "$value": "12px" }, "md": { "$value": "16px" },
    "lg": { "$value": "20px" }, "xl": { "$value": "24px" }, "2xl": { "$value": "32px" },
    "3xl": { "$value": "40px" }, "4xl": { "$value": "48px" }, "5xl": { "$value": "64px" },
    "6xl": { "$value": "80px" }, "7xl": { "$value": "96px" }
  },
  "radius": {
    "$type": "dimension",
    "xs": { "$value": "6px" }, "sm": { "$value": "8px" }, "md": { "$value": "12px" },
    "lg": { "$value": "16px" }, "xl": { "$value": "20px" }, "2xl": { "$value": "28px" },
    "full": { "$value": "999px" }
  },
  "shadow": {
    "$type": "shadow",
    "1": { "$value": "0 1px 3px rgba(14,20,43,0.06)" },
    "2": { "$value": "0 6px 16px rgba(14,20,43,0.06)" },
    "3": { "$value": "0 12px 28px rgba(14,20,43,0.1)" },
    "4": { "$value": "0 24px 56px rgba(14,20,43,0.16)" }
  },
  "duration": {
    "$type": "duration",
    "instant": { "$value": "80ms" }, "fast": { "$value": "140ms" }, "base": { "$value": "220ms" },
    "slow": { "$value": "320ms" }, "unfold": { "$value": "520ms" }, "settle": { "$value": "720ms" }
  },
  "easing": {
    "$type": "cubicBezier",
    "standard": { "$value": [0.2, 0, 0, 1] },
    "entrance": { "$value": [0.16, 1, 0.3, 1] },
    "exit": { "$value": [0.4, 0, 1, 1] },
    "spring": { "$value": [0.34, 1.4, 0.64, 1] }
  }
}
